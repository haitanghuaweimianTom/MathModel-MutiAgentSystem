# ===== Claude Code 配置 =====
# 是否让 analyzer/modeler/solver 使用 Claude Code 作为后端（而非 MiniMax）
DEFAULT_LLM_BACKEND=claude

# Claude Code CLI 路径（留空则自动搜索PATH）
CLAUDE_CODE_PATH=

# Claude Code 模型
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Claude Code MCP 工具列表（逗号分隔）
CLAUDE_MCP_TOOLS=bing_search,web_search,paper_search,sequentialthinking

# Claude Code MCP 配置文件路径
CLAUDE_MCP_CONFIG_PATH=E:/cherryClaw/math_modeling_multi_agent/config/mcp_config.json

# 允许使用 Claude Code 后端的 Agent 列表（JSON数组格式）
CLAUDE_ENABLED_AGENTS=["analyzer_agent","modeler_agent","solver_agent","research_agent","writer_agent"]
