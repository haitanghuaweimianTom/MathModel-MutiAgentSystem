# 数学建模多Agent系统 - 环境变量配置示例

# MiniMax API配置
MINIMAX_API_KEY=your_api_key_here
API_BASE_URL=https://api.minimax.chat/v1

# 默认模型配置
DEFAULT_MODEL=minimax-m2.7
FALLBACK_MODEL=minimax-m2.1

# 应用配置
DEBUG=false
APP_NAME=数学建模多Agent系统
APP_VERSION=2.0.0

# CORS配置（逗号分隔）
CORS_ORIGINS=*

# 数据库配置
DATABASE_URL=sqlite:///./data/agents.db

# Redis配置（可选）
REDIS_URL=redis://localhost:6379

# MCP服务器配置
MCP_SERVERS_PATH=./config/mcp_config.json

# 输出目录
OUTPUT_DIR=./output
